---
import { getWorks } from '../lib/sanity.js'
const works = await getWorks()
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anton Kruse</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/global.css">
</head>
<body>

<nav class="nav">
  <span class="nav-name" onclick="openInfo()">Anton Kruse</span>
  <button class="works-btn" id="works-btn" onclick="toggleWorks()">Works</button>
</nav>

<div id="matrix-container">
  <div class="matrix-outer">
    <svg id="connector-svg"></svg>
    <div class="matrix-cols" id="filter-matrix"></div>
    <div class="matrix-status">
      <span class="matrix-status-text" id="filter-status-text"></span>
      <button class="btn-clear" id="btn-clear" onclick="resetFilters()" style="display:none;">Clear ×</button>
    </div>
  </div>
</div>

<div class="view active" id="view-start">
  <div class="slideshow-zone" id="slideshow-zone"></div>
</div>

<div class="view" id="view-works">
  <div class="works-header">
    <div class="works-header-label" id="works-header-label"></div>
  </div>
  <div class="works-grid" id="works-grid"></div>
</div>

<div class="info-overlay" id="info-overlay" onclick="closeInfo(event)">
  <div class="info-blur-bg"></div>
  <div class="info-content" onclick="event.stopPropagation()">
    <div class="info-content-name">Anton Kruse</div>
    <div class="info-content-body">
      *1987 Frankfurt am Main<br>
      MFA Fine Arts, UdK Berlin<br>
      Masterclass, Prof. O. Eliasson<br>
      Lives and works in Berlin<br><br>
      <a href="mailto:studio@antonkruse.com">studio@antonkruse.com</a><br>
      <a href="https://instagram.com/antonkruse" target="_blank">@antonkruse</a><br><br>
      Represented by Galerie Nord, Berlin
    </div>
    <div class="info-close-hint">Click anywhere to close</div>
  </div>
</div>

<div class="lightbox" id="lightbox" onclick="closeLbBg(event)">
  <div class="lb-bar">
    <span class="lb-counter" id="lb-counter"></span>
    <button class="lb-close-btn" onclick="closeLb()">Close ×</button>
  </div>
  <div class="lb-img" id="lb-img"></div>
  <div class="lb-caption">
    <div>
      <div class="lb-title" id="lb-title"></div>
      <div class="lb-exhibition" id="lb-exhibition"></div>
    </div>
    <div class="lb-right">
      <div class="lb-year" id="lb-year"></div>
      <div class="lb-medium" id="lb-medium"></div>
    </div>
  </div>
  <div class="lb-bottom">
    <button class="lb-nav" onclick="lbNav(-1)">← Prev</button>
    <button class="lb-nav" onclick="lbNav(1)">Next →</button>
  </div>
</div>

<script define:vars={{ works }}>
const WORKS = works;

const FILTER_COLS = [
  ['2022','2023','2024','2025','2026'],
  ['Painting','Drawing','Photography','Sculpture'],
  ['Video','Installation','Mixed Media','Performance'],
  ['Exhibition','Documentation','Series','Commission'],
  ['Large Format','Monochrome','Abstract','Figurative'],
  ['Light','Sound','Site-specific','Text'],
];

let activeTags = new Set();
let slideList = [], slideIndex = 0, slideTimer = null;
let lbList = WORKS.map(w => w._id), lbCurrent = null;
let currentView = 'start';
const tagEls = {};

function renderMatrix() {
  const mat = document.getElementById('filter-matrix');
  mat.innerHTML = '';
  Object.keys(tagEls).forEach(k => delete tagEls[k]);
  FILTER_COLS.forEach(col => {
    const colEl = document.createElement('div');
    colEl.className = 'matrix-col';
    col.forEach(tag => {
      const span = document.createElement('span');
      span.className = 'ftag' + (activeTags.has(tag) ? ' active' : '');
      span.textContent = tag;
      span.onclick = () => toggleTag(tag);
      colEl.appendChild(span);
      tagEls[tag] = span;
    });
    mat.appendChild(colEl);
  });
  requestAnimationFrame(drawConnectors);
}

function getCenter(el, svgEl) {
  const eR = el.getBoundingClientRect();
  const sR = svgEl.getBoundingClientRect();
  return { x: eR.left - sR.left + eR.width/2, y: eR.top - sR.top + eR.height/2 };
}

function drawConnectors() {
  const svg = document.getElementById('connector-svg');
  svg.innerHTML = '';
  const active = [...activeTags];
  if (active.length < 2) return;
  const sRect = svg.getBoundingClientRect();
  if (!sRect.width) return;
  const centers = active.map(tag => {
    const el = tagEls[tag];
    if (!el) return null;
    return { tag, ...getCenter(el, svg) };
  }).filter(Boolean);
  for (let i = 0; i < centers.length - 1; i++) {
    for (let j = i + 1; j < centers.length; j++) {
      const a = centers[i], b = centers[j];
      const dx = b.x - a.x, dy = b.y - a.y;
      const len = Math.sqrt(dx*dx + dy*dy);
      const bend = Math.min(len * 0.28, 50);
      const cx1 = a.x + dx * 0.25, cy1 = Math.min(a.y, b.y) - bend;
      const cx2 = a.x + dx * 0.75, cy2 = Math.min(a.y, b.y) - bend;
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', `M${a.x},${a.y} C${cx1},${cy1} ${cx2},${cy2} ${b.x},${b.y}`);
      path.setAttribute('stroke', '#FFFFFF');
      path.setAttribute('stroke-width', '0.7');
      path.setAttribute('fill', 'none');
      path.setAttribute('opacity', '0.15');
      svg.appendChild(path);
      const t = 0.5;
      const mx = (1-t)**3*a.x + 3*(1-t)**2*t*cx1 + 3*(1-t)*t**2*cx2 + t**3*b.x;
      const my = (1-t)**3*a.y + 3*(1-t)**2*t*cy1 + 3*(1-t)*t**2*cy2 + t**3*b.y;
      const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('cx', mx); dot.setAttribute('cy', my);
      dot.setAttribute('r', '2'); dot.setAttribute('fill', '#FFFFFF'); dot.setAttribute('opacity', '0.2');
      svg.appendChild(dot);
    }
  }
}

function toggleTag(tag) {
  activeTags.has(tag) ? activeTags.delete(tag) : activeTags.add(tag);
  renderMatrix(); updateStatus();
  if (currentView === 'start') rebuildSlideshow();
  if (currentView === 'works') renderWorks();
}

function resetFilters() {
  activeTags.clear(); renderMatrix(); updateStatus();
  if (currentView === 'start') rebuildSlideshow();
  if (currentView === 'works') renderWorks();
}

function updateStatus() {
  const f = getFiltered();
  const txt = document.getElementById('filter-status-text');
  const btn = document.getElementById('btn-clear');
  if (!activeTags.size) {
    txt.textContent = '';
    btn.style.display = 'none';
  } else {
    txt.textContent = f.length + ' work' + (f.length !== 1 ? 's' : '') + ' — ' + [...activeTags].join(', ');
    btn.style.display = 'inline';
  }
}

function getFiltered() {
  if (!activeTags.size) return [...WORKS];
  return WORKS.filter(w => w.tags && [...activeTags].every(t => w.tags.includes(t)));
}

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length-1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function rebuildSlideshow() {
  slideList = shuffle(getFiltered());
  slideIndex = 0;
  clearInterval(slideTimer);
  const zone = document.getElementById('slideshow-zone');
  if (!slideList.length) {
    zone.innerHTML = '<div class="no-results-slide">No works match this selection</div>';
    return;
  }
  zone.innerHTML = `
    <div class="slideshow-frame" id="slideshow-frame"></div>
    <div class="slideshow-caption">
      <div class="caption-title" id="caption-title"></div>
      <div class="caption-sub" id="caption-sub"></div>
    </div>
    <div class="slideshow-dots" id="slideshow-dots"></div>`;
  const frame = document.getElementById('slideshow-frame');
  const dots = document.getElementById('slideshow-dots');
  slideList.forEach((w, i) => {
    const s = document.createElement('div');
    s.className = 'slide' + (i === 0 ? ' visible' : '');
    if (w.imageUrl) {
      const img = document.createElement('img');
      img.className = 'slide-bg';
      img.src = w.imageUrl;
      img.alt = w.title;
      s.appendChild(img);
    } else {
      const div = document.createElement('div');
      div.className = 'slide-color';
      div.style.background = 'rgba(255,255,255,0.06)';
      s.appendChild(div);
    }
    frame.appendChild(s);
    const d = document.createElement('div');
    d.className = 'dot' + (i === 0 ? ' active' : '');
    d.onclick = () => { slideIndex = i; showSlide(i); };
    dots.appendChild(d);
  });
  showSlide(0);
  if (slideList.length > 1) {
    slideTimer = setInterval(() => {
      slideIndex = (slideIndex + 1) % slideList.length;
      showSlide(slideIndex);
    }, 10000);
  }
}

function showSlide(idx) {
  document.querySelectorAll('.slide').forEach((s, i) => s.classList.toggle('visible', i === idx));
  document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === idx));
  const w = slideList[idx];
  if (!w) return;
  document.getElementById('caption-title').textContent = w.title;
  document.getElementById('caption-sub').textContent =
    w.medium + ' · ' + w.year + (w.exhibition ? ' · ' + w.exhibition : '');
}

function toggleWorks() {
  currentView === 'works' ? showView('start') : showView('works');
}

function renderWorks() {
  const works = getFiltered();
  lbList = works.map(w => w._id);
  document.getElementById('works-header-label').textContent =
    works.length + ' Work' + (works.length !== 1 ? 's' : '') + (activeTags.size ? ' — Filtered' : ' — All');
  const grid = document.getElementById('works-grid');
  if (!works.length) {
    grid.innerHTML = '<div class="works-empty">No works match this selection</div>';
    return;
  }
  grid.innerHTML = works.map(w => `
    <div class="work-item" onclick="openLb('${w._id}')">
      <div class="work-frame">
        ${w.imageUrl ? `<img src="${w.imageUrl}&w=600" alt="${w.title}" loading="lazy">` : ''}
      </div>
      <div class="work-meta">
        <div class="work-title">${w.title}</div>
        <div class="work-year">${w.year}</div>
      </div>
    </div>`).join('');
}

function showView(view) {
  currentView = view;
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  const btn = document.getElementById('works-btn');
  if (view === 'works') { btn.classList.add('active'); renderWorks(); }
  else { btn.classList.remove('active'); rebuildSlideshow(); }
  requestAnimationFrame(drawConnectors);
}

function openInfo() { document.getElementById('info-overlay').classList.add('open'); }
function closeInfo(e) { document.getElementById('info-overlay').classList.remove('open'); }

function openLb(id) {
  const w = WORKS.find(x => x._id === id);
  if (!w) return;
  lbCurrent = id;
  const lbImg = document.getElementById('lb-img');
  lbImg.innerHTML = w.imageUrl ? `<img src="${w.imageUrl}&w=920" alt="${w.title}">` : '';
  document.getElementById('lb-title').textContent = w.title;
  document.getElementById('lb-medium').textContent = w.medium || '';
  document.getElementById('lb-exhibition').textContent = w.exhibition || '';
  document.getElementById('lb-year').textContent = w.year;
  const idx = lbList.indexOf(id);
  document.getElementById('lb-counter').textContent =
    String(idx+1).padStart(2,'0') + ' / ' + String(lbList.length).padStart(2,'0');
  document.getElementById('lightbox').classList.add('open');
}

function closeLb() { document.getElementById('lightbox').classList.remove('open'); }
function closeLbBg(e) { if (e.target === document.getElementById('lightbox')) closeLb(); }
function lbNav(dir) {
  const idx = lbList.indexOf(lbCurrent);
  openLb(lbList[(idx + dir + lbList.length) % lbList.length]);
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.getElementById('info-overlay').classList.remove('open');
    closeLb();
  }
  if (document.getElementById('lightbox').classList.contains('open')) {
    if (e.key === 'ArrowRight') lbNav(1);
    if (e.key === 'ArrowLeft') lbNav(-1);
  }
});

window.addEventListener('resize', () => requestAnimationFrame(drawConnectors));
renderMatrix();
updateStatus();
rebuildSlideshow();
</script>
</body>
</html>
